 // Return value when handling keys in command-line mode.
 #define CMDLINE_NOT_CHANGED	1
@@ -5116,6 +5117,36 @@ get_user_input(
 
     prompt = tv_get_string_chk(&argvars[0]);
 
+    if (vim_core_bridge_embedded_mode_active() && prompt != NULL)
+    {
+	char	*response = NULL;
+	uintptr_t response_len = 0;
+	bool	cancelled = false;
+	vim_core_input_request_kind_t request_kind = secret
+		    ? VIM_CORE_INPUT_REQUEST_SECRET
+		    : VIM_CORE_INPUT_REQUEST_COMMAND_LINE;
+
+	if (vim_core_bridge_take_input_response(
+		    request_kind, &response, &response_len, &cancelled))
+	{
+	    if (cancelled)
+		rettv->vval.v_string = vim_strsave((char_u *)"");
+	    else if (response != NULL)
+		rettv->vval.v_string =
+		    vim_strnsave((char_u *)response, (int)response_len);
+	    else
+		rettv->vval.v_string = vim_strsave((char_u *)"");
+	    vim_core_bridge_free_input_response(response);
+	    return;
+	}
+
+	vim_core_bridge_enqueue_input_request(
+		(const char *)prompt,
+		(uintptr_t)STRLEN(prompt),
+		request_kind);
+	return;
+    }
