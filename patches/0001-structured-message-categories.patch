+		_(msgstr),
+		did_undo ? _("before") : _("after"),
+		uhp == NULL ? 0L : uhp->uh_seq,
+		msgbuf);
+	vim_core_bridge_enqueue_message_event(
+		status_msg,
+		(uintptr_t)STRLEN((char_u *)status_msg),
+		VIM_CORE_MESSAGE_SEVERITY_INFO,
+		VIM_CORE_MESSAGE_CATEGORY_COMMAND_FEEDBACK);
+    }
+    else
+	smsg_attr_keep(0, _("%ld %s; %s #%ld  %s"),
+		u_oldcount < 0 ? -u_oldcount : u_oldcount,
+		_(msgstr),
+		did_undo ? _("before") : _("after"),
+		uhp == NULL ? 0L : uhp->uh_seq,
+		msgbuf);
 }
 
