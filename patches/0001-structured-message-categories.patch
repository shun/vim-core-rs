@@ -54,6 +55,39 @@ static struct msg_hist *last_msg_hist = NULL;
 static int msg_hist_len = 0;
 static int msg_hist_max = 500;		// The default max value is 500
 
+    static vim_core_message_severity_t
+vim_core_message_severity_from_attr(int attr)
+{
+    int base_attr;
+
+    base_attr = attr & ~MSG_HIST;
+    if (base_attr == 0)
+	base_attr = HL_ATTR(HLF_MSG);
+
+    if (base_attr == HL_ATTR(HLF_E))
+	return VIM_CORE_MESSAGE_SEVERITY_ERROR;
+    if (base_attr == HL_ATTR(HLF_W))
+	return VIM_CORE_MESSAGE_SEVERITY_WARNING;
+    return VIM_CORE_MESSAGE_SEVERITY_INFO;
+}
+
+    static int
+vim_core_enqueue_embedded_message(
+    const char *message,
+    int attr,
+    vim_core_message_category_t category)
+{
+    if (!vim_core_bridge_embedded_mode_active() || message == NULL || *message == NUL)
+	return FALSE;
+
+    vim_core_bridge_enqueue_message_event(
+	message,
+	(uintptr_t)STRLEN((char_u *)message),
+	vim_core_message_severity_from_attr(attr),
+	category);
+    return TRUE;
+}
+
 // flags obtained from the 'messagesopt' option
 #define MESSAGES_HIT_ENTER	0x001
 #define MESSAGES_WAIT		0x002
